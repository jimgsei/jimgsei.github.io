<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Canales España</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 0;
            margin: 0;
            height: 100vh;
            overflow: hidden;
            background-color: #f0f0f0;
        }
        video {
            width: 100%;
            height: 30vh;
            margin: 0;
        }
        h1 {
            font-size: 24px;
            margin: 20px 0;
            cursor: pointer;
        }
        #category-list {
            display: flex;
            gap: 10px;
            width: 80%;
            max-width: 600px;
            overflow-x: auto;
            padding: 10px;
            background: #fff;
            border: 1px solid #ccc;
            border-radius: 8px;
            margin-bottom: 10px;
        }
        .category-item {
            background-color: #e0e0e0;
            padding: 10px;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s;
            white-space: nowrap;
        }
        .category-item:hover {
            background-color: #d0d0d0;
        }
        #channel-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            width: 80%;
            max-width: 600px;
            max-height: 30vh;
            overflow-y: auto;
            padding: 10px;
            background: #fff;
            border: 1px solid #ccc;
            border-radius: 8px;
        }
        .channel-item {
            background-color: #e0e0e0;
            padding: 10px;
            border-radius: 5px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: background-color 0.3s;
        }
        .channel-item:hover {
            background-color: #d0d0d0;
        }
        .channel-item span {
            flex: 1;
        }
        .channel-item i {
            color: #555;
        }
    </style>
</head>
<body>
    <video id="video-player" controls></video>
    <h1 id="page-title">Selecciona una fuente</h1>
    <div id="category-list"></div>
    <div id="channel-list"></div>
    <script>
        const player = document.getElementById('video-player');
        const pageTitle = document.getElementById('page-title');
        const proxyUrl = 'https://api.codetabs.com/v1/proxy/?quest=';
        let selectedSource = '';
        const sources = {
            'source-huhu': 'https://huhu.to/play/',
            'source-kool': 'https://kool.to/play/',
            'source-oha': 'https://oha.to/play/'
        };
        let categories = {};
        let allChannels = [];

        pageTitle.addEventListener('click', async () => {
            const sourceKeys = Object.keys(sources);
            const currentSource = sourceKeys.find(key => sources[key] === selectedSource) || sourceKeys[0];
            const nextSourceIndex = (sourceKeys.indexOf(currentSource) + 1) % sourceKeys.length;
            selectedSource = sources[sourceKeys[nextSourceIndex]];
            pageTitle.textContent = `Fuente: ${sourceKeys[nextSourceIndex]}`;
            await loadChannels();
        });

        async function loadChannels() {
            try {
                const response = await fetch(proxyUrl + 'https://vavoo.to/channels');
                const data = await response.json();
                categories = {};
                allChannels = [];
                data.filter(item => item.country === 'Spain').forEach(item => {
                    const { id, name } = item;
                    const channelUrl = selectedSource + id + '/index.m3u8';
                    const channel = { id, name, url: channelUrl };
                    allChannels.push(channel);
                });
                populateChannelList(allChannels);
            } catch (error) {
                console.error(error);
                alert('Error al cargar los canales: ' + error.message);
            }
        }

        function populateChannelList(channelList) {
            const channelListContainer = document.getElementById('channel-list');
            channelListContainer.innerHTML = '';
            channelList.forEach(channel => {
                const channelItem = document.createElement('div');
                channelItem.classList.add('channel-item');
                channelItem.dataset.url = channel.url;
                channelItem.innerHTML = `<span>${channel.name}</span><i class="fas fa-play"></i>`;
                channelItem.addEventListener('click', () => {
                    player.src = channel.url;
                    player.play();
                });
                channelListContainer.appendChild(channelItem);
            });
        }

        // Initialize the first source
        selectedSource = sources['source-oha'];
        pageTitle.textContent = 'Fuente: source-oha';
        loadChannels();
    </script>
</body>
</html>
